### onedrive @ adobe.sharepoint.com  (Adobe corp tenant)
### authoringType = documentauthoring
### deliveryConfig.mysticatLegacyAutofixBridgeOpportunities = ["broken-backlinks"]  (hyphen)
### ========================================

### 1. Get site
GET https://{{DEV_HOST}}/api/ci/sites/{{site3}}
x-api-key: {{apiKey}}

### 2. List opportunities
GET https://{{DEV_HOST}}/api/ci/sites/{{site3}}/opportunities
x-api-key: {{apiKey}}

### 2b. NEW only
GET https://{{DEV_HOST}}/api/ci/sites/{{site3}}/opportunities/by-status/NEW
x-api-key: {{apiKey}}

### 3. List suggestions
GET https://{{DEV_HOST}}/api/ci/sites/{{site3}}/opportunities/{{opp3}}/suggestions
x-api-key: {{apiKey}}

### 4. Reset suggestion status to NEW
PATCH https://{{DEV_HOST}}/api/ci/sites/{{site3}}/opportunities/{{opp3}}/suggestions/status
Content-Type: application/json
x-api-key: {{apiKey}}

[
  { "id": "{{suggestion3}}", "status": "NEW" }
]

### 5. Trigger autofix (needs Bearer for IMS promise token)
PATCH https://{{DEV_HOST}}/api/ci/sites/{{site3}}/opportunities/{{opp3}}/suggestions/auto-fix
Content-Type: application/json
x-api-key: {{apiKey}}
Authorization: Bearer {{imsToken}}

{
  "suggestionIds": ["{{suggestion3}}"]
}

### ========================================
### Optional: bulk multiple suggestions in one trigger
### Replace the body with multiple ids
### ========================================
PATCH https://{{DEV_HOST}}/api/ci/sites/{{site1}}/opportunities/{{opp1}}/suggestions/auto-fix
Content-Type: application/json
x-api-key: {{apiKey}}
Authorization: Bearer {{imsToken}}

{
  "suggestionIds": [
    "{{suggestion1}}"
  ]
}

### ========================================
### Alternative: skip the promise token entirely with action=assess + precheckOnly
### From suggestions.js:1239 - only this combination skips getIMSPromiseToken().
### Useful if you only want to verify the autofix path executes without a Bearer.
### ========================================
PATCH https://{{DEV_HOST}}/api/ci/sites/{{site1}}/opportunities/{{opp1}}/suggestions/auto-fix
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "suggestionIds": ["{{suggestion1}}"],
  "action": "assess",
  "precheckOnly": true
}
