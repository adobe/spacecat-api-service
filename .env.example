# SpaceCat API Service — Local Development Environment Variables
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# See test/it/env.js for the canonical list used by integration tests.

# ── Data access (PostgreSQL) ──────────────────────────────────────────────────
# Option 1 (IT docker-compose): POSTGREST_URL=http://localhost:3300
# Option 2 (mysticat-data-service): POSTGREST_URL=http://localhost:3000
DATA_SERVICE_PROVIDER=postgres
POSTGREST_URL=http://localhost:3300
POSTGREST_SCHEMA=public
# Pre-generated JWT for the local-dev secret (PGRST_JWT_SECRET in docker-compose.yml).
# To regenerate (e.g. if the secret changes):
#   node -e "const c=require('crypto'),s='local-dev-jwt-secret-for-postgrest-only',b=d=>Buffer.from(d).toString('base64').replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/g,''),h=b(JSON.stringify({alg:'HS256',typ:'JWT'})),p=b(JSON.stringify({role:'postgrest_writer'}));console.log(h+'.'+p+'.'+b(c.createHmac('sha256',s).update(h+'.'+p).digest()))"
POSTGREST_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoicG9zdGdyZXN0X3dyaXRlciJ9.qEUB9zeY8WHpgyyRRBgs5th4WY98pJfUudtCwImM4H4

# ── AWS (needed for SDK client init, dummy values are fine locally) ───────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# ── Auth (API keys for local requests) ────────────────────────────────────────
USER_API_KEY=api_key_for_user_requests
ADMIN_API_KEY=api_key_for_admin_requests

# ── IMS client (eagerly initialized, dummy values are fine) ───────────────────
IMS_HOST=https://dummy-ims.example.com
IMS_CLIENT_ID=dummy-client-id
IMS_CLIENT_CODE=dummy-client-code
IMS_CLIENT_SECRET=dummy-client-secret

# ── Slack client (eagerly initialized) ────────────────────────────────────────
SLACK_TOKEN_WORKSPACE_EXTERNAL_ELEVATED=xoxb-dummy-token
SLACK_OPS_CHANNEL_WORKSPACE_EXTERNAL=C000DUMMY
SLACK_URL_WORKSPACE_EXTERNAL=https://dummy-slack.example.com

# ── Queue URLs & S3 buckets (dummy values, not called locally) ────────────────
AUDIT_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/dummy-audits
REPORT_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/dummy-reports
S3_REPORT_BUCKET=dummy-report-bucket
S3_MYSTIQUE_BUCKET=dummy-mystique-bucket
S3_CONFIG_BUCKET=dummy-config-bucket
S3_SCRAPER_BUCKET=dummy-scraper-bucket

# ── Scrape client (eagerly parsed in constructor) ─────────────────────────────
SCRAPE_JOB_CONFIGURATION={"queues":[],"scrapeWorkerQueue":"https://sqs.us-east-1.amazonaws.com/000000000000/dummy-scrape","s3Bucket":"dummy-scrape-bucket","options":{},"maxUrlsPerJob":4000,"maxUrlsPerMessage":1000,"scrapeQueueUrlPrefix":"https://sqs.us-east-1.amazonaws.com/000000000000/dummy"}

# ── JSON configs (empty objects are valid) ────────────────────────────────────
IMPORT_CONFIGURATION={}
API_KEY_CONFIGURATION={}

# ── Mystique (preflight beta endpoints) ──────────────────────────────────────
# Base URL of the Mystique service.
# MYSTIQUE_API_BASE_URL=https://mystique.example.com


# ── Misc ──────────────────────────────────────────────────────────────────────
DEFAULT_ORGANIZATION_ID=11111111-1111-4111-b111-111111111111
S2S_ALLOWED_IMS_ORG_IDS=dummy@AdobeOrg

# ── Server port (optional, default 3002) ──────────────────────────────────────
# PORT=3001