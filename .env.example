# SpaceCat API Service вЂ” Local Development Environment Variables
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# See test/it/env.js for the canonical list used by integration tests.

# в”Ђв”Ђ Data access (PostgreSQL) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Option 1 (IT docker-compose): POSTGREST_URL=http://localhost:3300
# Option 2 (mysticat-data-service): POSTGREST_URL=http://localhost:3000
DATA_SERVICE_PROVIDER=postgres
POSTGREST_URL=http://localhost:3300
POSTGREST_SCHEMA=public
# Pre-generated JWT for the local-dev secret (PGRST_JWT_SECRET in docker-compose.yml).
# To regenerate (e.g. if the secret changes):
#   node -e "const c=require('crypto'),s='local-dev-jwt-secret-for-postgrest-only',b=d=>Buffer.from(d).toString('base64').replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/g,''),h=b(JSON.stringify({alg:'HS256',typ:'JWT'})),p=b(JSON.stringify({role:'postgrest_writer'}));console.log(h+'.'+p+'.'+b(c.createHmac('sha256',s).update(h+'.'+p).digest()))"
POSTGREST_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoicG9zdGdyZXN0X3dyaXRlciJ9.qEUB9zeY8WHpgyyRRBgs5th4WY98pJfUudtCwImM4H4

# в”Ђв”Ђ AWS (needed for SDK client init, dummy values are fine locally) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# в”Ђв”Ђ Auth (API keys for local requests) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
USER_API_KEY=api_key_for_user_requests
ADMIN_API_KEY=api_key_for_admin_requests

# в”Ђв”Ђ IMS client (eagerly initialized, dummy values are fine) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
IMS_HOST=https://dummy-ims.example.com
IMS_CLIENT_ID=dummy-client-id
IMS_CLIENT_CODE=dummy-client-code
IMS_CLIENT_SECRET=dummy-client-secret

# в”Ђв”Ђ Slack client (eagerly initialized) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SLACK_TOKEN_WORKSPACE_EXTERNAL_ELEVATED=xoxb-dummy-token
SLACK_OPS_CHANNEL_WORKSPACE_EXTERNAL=C000DUMMY
SLACK_URL_WORKSPACE_EXTERNAL=https://dummy-slack.example.com

# в”Ђв”Ђ Queue URLs & S3 buckets (dummy values, not called locally) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AUDIT_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/dummy-audits
REPORT_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/dummy-reports
S3_REPORT_BUCKET=dummy-report-bucket
S3_MYSTIQUE_BUCKET=dummy-mystique-bucket
S3_CONFIG_BUCKET=dummy-config-bucket
S3_SCRAPER_BUCKET=dummy-scraper-bucket

# в”Ђв”Ђ Scrape client (eagerly parsed in constructor) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SCRAPE_JOB_CONFIGURATION={"queues":[],"scrapeWorkerQueue":"https://sqs.us-east-1.amazonaws.com/000000000000/dummy-scrape","s3Bucket":"dummy-scrape-bucket","options":{},"maxUrlsPerJob":4000,"maxUrlsPerMessage":1000,"scrapeQueueUrlPrefix":"https://sqs.us-east-1.amazonaws.com/000000000000/dummy"}

# в”Ђв”Ђ JSON configs (empty objects are valid) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
IMPORT_CONFIGURATION={}
API_KEY_CONFIGURATION={}

# в”Ђв”Ђ Mystique (preflight beta endpoints) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Base URL of the Mystique service.
# MYSTIQUE_API_BASE_URL=https://mystique.example.com


# в”Ђв”Ђ Misc в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DEFAULT_ORGANIZATION_ID=11111111-1111-4111-b111-111111111111
S2S_ALLOWED_IMS_ORG_IDS=dummy@AdobeOrg

# в”Ђв”Ђ AI Visibility (Semrush gRPC OAuth) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SEO_CLIENT_ID=
SEO_CLIENT_SECRET=
# SEO_OAUTH_SCOPES=ai-seo.meta ai-seo.topics ai-seo.prompts ai-seo.sources ai-seo.brand-metrics ai-seo.relations ai-seo.competitors-metrics ai-seo.competitor
# SEO_OAUTH_TOKEN_URL=

# в”Ђв”Ђ Semrush AIO proxy (REST) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Required for /serenity/* endpoints. Vault-backed in dev/stage/prod under
# dx_mysticat/<env>/api-service. Must be https. No source default вЂ” the proxy
# throws 503 configurationError at first request if unset.
#
# Uncomment + set the value for local dev. The example below is the current
# hackathon host (dx_mysticat/dev/api-service value as of 2026-05-22); leave
# it commented in the checked-in template so `cp .env.example .env` doesn't
# silently point a fresh local stack at the live upstream.
# SEMRUSH_PROJECTS_BASE_URL=https://adobe-hackathon.semrush.com

# в”Ђв”Ђ Server port (optional, default 3002) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# PORT=3001