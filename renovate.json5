{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "extends": [
    "local>adobe/spacecat-api-service"
  ],
  // Pin Renovate's worker to Node 24 so `npm install` succeeds against the
  // repo's strict engines.node range. Without this, Renovate silently skips
  // updating package-lock.json on every dep PR, breaking `npm ci` on main
  // until someone re-syncs the lock manually.
  "constraints": {
    "node": "24"
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "jsdom"
      ],
      "allowedVersions": "<27.0.0"
    },
    {
      "matchPackageNames": [
        "semantic-release"
      ],
      "allowedVersions": ">=23.0"
    },
    {
      "matchPackageNames": [
        "zod"
      ],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchPackageNames": [
        "@adobe/spacecat-shared-data-access"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "eslint"
      ],
      "allowedVersions": "<10.0.0"
    },
    {
      "matchPackagePatterns": [
        "^@langchain/"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ]
}
