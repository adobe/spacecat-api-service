{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "extends": [
    "local>adobe/spacecat-api-service"    ,{
      "matchPackageNames": [
        "eslint"
      ],
      "allowedVersions": "<10.0.0"
    }
  ],
  "packageRules": [
    {
        "matchPackageNames": [
            "jsdom"
        ],
        "allowedVersions": "<27.0.0"
    },
    {
      "matchPackageNames": [
        "semantic-release"
      ],
      "allowedVersions": ">=23.0"
    },
    {
      "matchPackageNames": [
        "zod"
      ],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchPackageNames": [
        "@adobe/spacecat-shared-data-access"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }    ,{
      "matchPackageNames": [
        "eslint"
      ],
      "allowedVersions": "<10.0.0"
    }
  ]
}
