{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    // checkJs:false + a per-file `// @ts-check` pragma is the opt-in seam: only
    // annotated files are error-reported; the rest of the graph is parsed for
    // types only. (checkJs:true would report the whole reachable graph.)
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    // Pragmatic relaxations under strict (ratcheted to true later — see
    // docs/decisions/005-opt-in-type-checking.md): skip implicit-any param noise
    // and keep catch vars as `any` so this pass isn't dominated by catch-narrowing.
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/support/serenity/**/*.js",
    "src/support/url-utils.js",
    "src/controllers/serenity.js",
    "src/controllers/brands.js",
    "src/dto/preflight.js"
  ]
}
